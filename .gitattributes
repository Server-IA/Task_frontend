# Normalizar todos los archivos de texto a LF (Linux/Mac) al commitear.
# Evita el ruido de LF→CRLF en Windows.
* text=auto eol=lf

# Archivos binarios — sin conversión
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
